{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83d\ude80 \u6df1\u5733\u6280\u672f\u5927\u5b66\u98de\u8dc3\u624b\u518c (SZTU Feiyue)","text":"<p>\u6b22\u8fce\uff01\u6df1\u5733\u6280\u672f\u5927\u5b66\u98de\u8dc3\u624b\u518c\u662f\u4e00\u4efd\u6c47\u805a\u6df1\u5733\u6280\u672f\u5927\u5b66\u5f80\u5c4a\u751f\u7559\u5b66\u3001\u4fdd\u7814\u3001\u8003\u7814\u3001\u5c31\u4e1a\u56db\u4e2a\u5927\u65b9\u5411\u7684\u6848\u4f8b\u4e0e\u7ecf\u9a8c\u5206\u4eab\u7f51\u7ad9\u3002</p>"},{"location":"#_1","title":"\ud83c\udf89 \u5199\u5728\u524d\u9762","text":"<p>\u8fd9\u4efd\u624b\u518c\u65e8\u5728\u6253\u7834\u4fe1\u606f\u5dee\uff0c\u5e2e\u52a9\u5b66\u5f1f\u5b66\u59b9\u4eec\u5c11\u8d70\u5f2f\u8def\u3002\u65e0\u8bba\u4f60\u7684\u76ee\u6807\u662f\u5347\u5b66\u8fd8\u662f\u5c31\u4e1a\uff0c\u5728\u8fd9\u91cc\u90fd\u80fd\u627e\u5230\u524d\u4eba\u7684\u8db3\u8ff9\u3002</p>"},{"location":"#_2","title":"\ud83d\udccd \u5feb\u901f\u5bfc\u822a","text":"\ud83d\udeeb \u7559\u5b66 \ud83d\udcd6 \u4fdd\u7814 \u270d\ufe0f \u8003\u7814 \ud83d\udcbc \u5c31\u4e1a \u524d\u5f80\u7559\u5b66\u677f\u5757 \u524d\u5f80\u4fdd\u7814\u677f\u5757 \u524d\u5f80\u8003\u7814\u677f\u5757 \u524d\u5f80\u5c31\u4e1a\u677f\u5757"},{"location":"#_3","title":"\ud83e\udd1d \u8d21\u732e\u8bf4\u660e","text":"<p>\u5927\u5bb6\u53ef\u4ee5\u5c06\u81ea\u5df1\u7684\u7ecf\u9a8c\u6574\u7406\u6210\u6587\u6863\u53d1\u9001\u7ed9\u6211\u4eec\uff0c\u6216\u8005\u662f\u901a\u8fc7 GitHub Pull Request \u63d0\u4ea4\u3002\u4f60\u4eec\u7684\u4e00\u70b9\u70b9\u5e2e\u52a9\uff0c\u90fd\u80fd\u6210\u4e3a\u4ed6\u4eba\u8fdc\u5927\u5f81\u7a0b\u4e0a\u7684\u4e00\u5757\u57ab\u811a\u77f3\uff01</p>"},{"location":"baoyan/","title":"\ud83d\udcd6 \u4fdd\u7814\u677f\u5757","text":"<p>\u672c\u9875\u9762\u8bb0\u5f55\u4e86 SZTU \u540c\u5b66\u4eec\u7684\u590f\u4ee4\u8425\u3001\u9884\u63a8\u514d\u4ee5\u53ca\u4e5d\u63a8\u7684\u5b9d\u8d35\u7ecf\u5386\u4e0e\u9762\u8bd5\u7ecf\u9a8c\u6c47\u603b\u3002</p>"},{"location":"baoyan/#_2","title":"\ud83d\udccd \u5185\u5bb9\u6db5\u76d6","text":"<ul> <li>\u590f\u4ee4\u8425\u5165\u8425\u8981\u6c42\u4e0e\u80cc\u666f\u63d0\u5347</li> <li>\u9762\u8bd5\u4e13\u4e1a\u8bfe\u590d\u4e60\u6307\u5357</li> <li>\u673a\u8bd5\u771f\u9898\u5206\u4eab</li> <li>\u5bfc\u5e08\u5957\u78c1\u5efa\u8bae</li> </ul>"},{"location":"jiuye/","title":"\ud83d\udcbc \u5c31\u4e1a\u677f\u5757","text":"<p>\u4ece\u4e92\u8054\u7f51\u5927\u5382\u5230\u4f53\u5236\u5185\uff0c\u4ece\u7b80\u5386\u6295\u9012\u5230\u7b14\u9762\u8bd5\u7ecf\u9a8c\u3002\u8fd9\u4efd\u5c31\u4e1a\u624b\u518c\u5c06\u5e26\u4f60\u62c6\u89e3\u6c42\u804c\u5168\u6d41\u7a0b\u3002</p>"},{"location":"jiuye/#_2","title":"\u70ed\u95e8\u5c97\u4f4d\u4e0e\u9762\u7ecf","text":"<ul> <li>\u8f6f\u4ef6\u7814\u53d1\u5de5\u7a0b\u5e08 (\u7814\u53d1\u3001\u7b97\u6cd5\u3001\u6d4b\u8bd5\u3001\u5ba2\u6237\u7aef...)</li> <li>\u4ea7\u54c1\u7ecf\u7406</li> <li>\u8fd0\u8425\u3001\u6570\u636e\u5206\u6790</li> <li>\u9009\u8c03\u751f\u4e0e\u8003\u516c\u6307\u5357</li> </ul> <p>\u8ba9\u6bcf\u6b21\u9762\u8bd5\u90fd\u53d8\u6210\u4e3a\u4f60\u91cf\u8eab\u5b9a\u505a\u7684\u821e\u53f0\u3002</p>"},{"location":"kaoyan/","title":"\u270d\ufe0f \u8003\u7814\u677f\u5757","text":"<p>\u4ece\u521d\u8bd5\u5907\u8003\u5230\u590d\u8bd5\u4e0a\u5cb8\uff0c\u8003\u7814\u5c31\u50cf\u662f\u5728\u9ed1\u5c4b\u5b50\u91cc\u6d17\u8863\u670d\uff0c\u6ca1\u5230\u6d17\u51fa\u6765\u7684\u90a3\u4e00\u523b\uff0c\u8c01\u90fd\u4e0d\u77e5\u9053\u6d17\u5e72\u51c0\u6ca1\u6709\u3002</p> <p>\u5728\u8fd9\u91cc\uff0c\u4f60\u80fd\u770b\u5230 SZTU \u5b66\u957f\u5b66\u59d0\u5173\u4e8e\u590d\u4e60\u89c4\u5212\u3001\u4e13\u4e1a\u8bfe\u8d44\u6599\u4e0e\u5fc3\u6001\u8c03\u8282\u7684\u8d85\u5e72\u8d27\u5206\u4eab\uff01</p> <p>\ud83d\udcaa \u201c\u4e0d\u8981\u653e\u5f03\uff0c\u71ac\u8fc7\u53bb\u5c31\u662f\u6674\u7a7a\uff01\u201d</p>"},{"location":"liuxue/","title":"\ud83d\udeeb \u7559\u5b66\u677f\u5757","text":"<p>\u672c\u9875\u9762\u6536\u5f55 SZTU \u524d\u8f88\u4eec\u7533\u8bf7\u6d77\u5916\u53ca\u6e2f\u6fb3\u53f0\u5730\u533a\u9ad8\u6821\u7684\u6210\u529f\u7ecf\u9a8c\u4e0e\u5931\u8d25\u6559\u8bad\u3002</p>"},{"location":"liuxue/#_2","title":"\ud83d\udc49 \u4e13\u4e1a\u5206\u7c7b","text":"<ul> <li>\u8ba1\u7b97\u673a\u5927\u7c7b</li> <li>\u5de5\u7a0b\u5927\u7c7b</li> <li>\u5546\u79d1\u65b9\u5411</li> <li>\u7406\u5b66\u65b9\u5411 ...</li> </ul> <p>\u5728\u8fd9\u91cc\uff0c\u4f60\u4e0d\u4ec5\u80fd\u627e\u5230\u6210\u529f\u62ff\u5230 Offer \u7684\u540c\u5b66\u7684\u80cc\u666f\u4e0e\u5fc3\u8def\u5386\u7a0b\uff0c\u8fd8\u80fd\u770b\u5230\u8bed\u8a00\u8003\u8bd5\uff08\u96c5\u601d/\u6258\u798f\uff09\u4e0e\u9009\u6821\u653b\u7565\u3002</p>"}]}